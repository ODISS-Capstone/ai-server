{
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "Tool_Get_Drug_Identification",
        "description": "의약품의 외형적 특성(모양, 색상, 각인 등)을 기반으로 품목명과 제조사를 확인한다. OCR 결과에 의약품명이 불분명하고 외형 기술만 있을 때 사용한다. (HIRA 의약품 낱알식별 API)",
        "parameters": {
          "type": "object",
          "properties": {
            "item_name": {"type": "string", "description": "품목명 (일부 일치 가능)"},
            "entp_name": {"type": "string", "description": "제조사/품목허가자"},
            "item_seq": {"type": "string", "description": "품목기준코드"},
            "print_front": {"type": "string", "description": "앞면 각인"},
            "print_back": {"type": "string", "description": "뒷면 각인"},
            "drug_shape": {"type": "string", "description": "제형 모양 (예: 원형, 타원형)"},
            "color_class1": {"type": "string", "description": "색상 (예: 하양, 노랑)"},
            "page_no": {"type": "integer", "minimum": 1, "default": 1},
            "num_of_rows": {"type": "integer", "minimum": 1, "maximum": 100, "default": 10}
          }
        }
      }
    },
    {
      "type": "function",
