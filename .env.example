# Server
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
APP_TIMEZONE=Asia/Seoul

# Database (SQLite for dev; MySQL for production / MCP)
DATABASE_URL=sqlite+aiosqlite:///./data/senior_med.db
# DATABASE_URL=mysql+aiomysql://user:pass@localhost:3306/senior_med

# MD Database Layer (Markdown 기반 데이터 저장소)
MD_DATABASE_PATH=./data/md_database

# Identity gate
IDENTITY_REVERIFY_WINDOW_SECONDS=3600
IDENTITY_PENDING_TIMEOUT_SECONDS=300

# 공공데이터포털 서비스키 (data.go.kr — DUR, HIRA, 건기식 API 공통)
DATA_GO_KR_SERVICE_KEY=

# DUR API (식약처 — T2~T10)
DUR_API_BASE_URL=http://apis.data.go.kr/1471000

# 의약품 낱알식별 API (HIRA — T1)
HIRA_API_BASE_URL=http://apis.data.go.kr/1471000/MdcinGrnIdntfcInfoService03

# 건강기능식품 API (T11, T12)
HEALTH_SUPPLEMENT_API_BASE_URL=http://apis.data.go.kr/1471000/HtfsSttusIdntfcInfoService01

# OCR - DeepSeek (or compatible API)
DEEPSEEK_OCR_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_OCR_API_KEY=

# KPIC DUR API (약학정보원)
KPIC_DUR_API_URL=
KPIC_DUR_API_KEY=

# Internal LLM (Ollama — OpenAI-compatible)
INTERNAL_LLM_PROVIDER=ollama
INTERNAL_LLM_API_URL=http://127.0.0.1:11434/v1/chat/completions
INTERNAL_LLM_API_KEY=
INTERNAL_LLM_MODEL=qwen3:4b
INTERNAL_LLM_FALLBACK_MODELS=
LLM_PROMPTS_PATH=./app/prompts/llm_prompts.json
LLM_TOOLS_PATH=./app/prompts/llm_tools.json
INTERNAL_LLM_TIMEOUT_SECONDS=60.0
INTERNAL_LLM_REASONING_ENABLED=
LOCAL_DELIVERY_LLM_TIMEOUT_SECONDS=30.0
CONVERSATION_LLM_BACKEND=local
CONVERSATION_LLM_FALLBACK_ENABLED=true
TOGETHER_CONVERSATION_MODEL=Qwen/Qwen3.5-9B
TOGETHER_CONVERSATION_FALLBACK_MODELS=
TOGETHER_CONVERSATION_TIMEOUT_SECONDS=10.0
# Together hybrid models can spend extra latency on reasoning.
# Keep conversation reasoning off; enable judge/search only when needed.
TOGETHER_CONVERSATION_REASONING_ENABLED=false
TOGETHER_JUDGE_REASONING_ENABLED=
TOGETHER_SEARCH_REASONING_ENABLED=
LLM_ENGINE_MAX_CONCURRENCY_INTERNAL=1
LLM_ENGINE_MAX_CONCURRENCY_EXTERNAL=1
LLM_ENGINE_MAX_CONCURRENCY_JUDGE=1
LLM_ENGINE_MAX_CONCURRENCY_SEARCH=1
LLM_ENGINE_MAX_CONCURRENCY_TOOL=4
LLM_ENGINE_MAX_CONCURRENCY_DUR=4

# External LLM (OpenAI — LLM as a Judge + LLM Search)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_JUDGE_MODEL=gpt-5
# Used by scripts/generate_reasoning_dataset.py (Qwen reasoning SFT data gen)
OPENAI_DATASET_MODEL=gpt-5.5
# or ANTHROPIC_API_KEY, GOOGLE_AI_API_KEY

# Together AI (OpenAI-compatible frontier provider)
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.ai/v1/chat/completions
TOGETHER_MODEL=Qwen/Qwen3.5-9B
TOGETHER_JUDGE_MODEL=Qwen/Qwen3.5-9B
TOGETHER_JUDGE_FALLBACK_MODELS=
TOGETHER_SEARCH_MODEL=Qwen/Qwen3.5-9B
TOGETHER_SEARCH_FALLBACK_MODELS=
TOGETHER_TIMEOUT_SECONDS=6.0

# Frontier provider routing (comma-separated: openai,together)
FRONTIER_LLM_ENABLED_PROVIDERS=openai,together
FRONTIER_LLM_PRIMARY_PROVIDER=openai
FRONTIER_LLM_FALLBACK_ENABLED=true

# MCP
MCP_SERVER_URL=
MCP_TRANSPORT=stdio

# File storage (NFS path or local)
STORAGE_PATH=./data/storage
NFS_MOUNT_PATH=

# Memory browser (read-only patient memory web UI)
# production/staging: Bearer token required on /api/memory/*
# development: token unset allows unauthenticated access
MEMORY_BROWSER_TOKEN=
MEMORY_BROWSER_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Deployable assistant web app
# production/staging: required for /app testers, /api/feedback/* and /ws/chat?token=
# development: unset allows local testing without a token
ASSISTANT_WEB_TOKEN=
ASSISTANT_WEB_DIST_PATH=./web/dist

# TTS / STT (optional)
CLOVA_STT_CLIENT_ID=
CLOVA_STT_CLIENT_SECRET=
CLOVA_TTS_CLIENT_ID=
CLOVA_TTS_CLIENT_SECRET=

# TurboQuant compressed KV cache (applied to every transformers model)
TURBOQUANT_AUTO_WRAP=true
TURBOQUANT_KEY_BITS=3
TURBOQUANT_VALUE_BITS=3
TURBOQUANT_COMPRESS_VALUES=false
TURBOQUANT_REQUIRE_CUDA=false
